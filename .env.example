# ─────────────────────────────────────────────────────────────────
#  .env.example — copy to .env and fill in your real values
#  Load via: python-dotenv (automatic via main.py) or set manually
# ─────────────────────────────────────────────────────────────────

# ── Ollama (LLM) ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_TIMEOUT=120

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./product_intelligence.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/product_intel

# ── Google Ads Keyword Planner API (Tier 1 — most accurate CPC) ───
# Sign up at: https://developers.google.com/google-ads/api/docs/get-started/introduction
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_LOGIN_CUSTOMER_ID=123-456-7890

# ── SerpAPI (Tier 2 — fallback keyword research) ──────────────────
# Free tier: 100 searches/month — https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# ── If neither API key is set, Tier 3 (SERP ad-count scraping) ────
# is used automatically. No key required.
